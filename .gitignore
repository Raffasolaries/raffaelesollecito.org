# Build artifacts
modules/cloudfront/lambda_redirect/dst/*
modules/codebuild/codebuild_files/wordpress_docker.zip
modules/codebuild/codebuild_files/php.ini

# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Lock file
.terraform.lock.hcl

# Plan files
plan.plan
*.tfplan

# Crash log files
crash.log
crash.*.log

# Variable files — contain environment-specific values and secrets.
